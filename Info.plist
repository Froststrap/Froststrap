<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Froststrap</string>
    <key>CFBundleDisplayName</key>
    <string>Froststrap</string>
    <key>CFBundleIdentifier</key>
    <string>io.github.froststrap.app</string>
    <key>CFBundleVersion</key>
    <string>2.0.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>Froststrap</string>
    <key>LSMinimumSystemVersion</key>
    <string>10.15</string>

    <!-- Register the URL schemes -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>Roblox Player Protocol</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>roblox-player</string>
                <string>roblox</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleURLName</key>
            <string>Roblox Studio Protocol</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>roblox-studio</string>
            </array>
        </dict>
    </array>
</dict>
</plist>