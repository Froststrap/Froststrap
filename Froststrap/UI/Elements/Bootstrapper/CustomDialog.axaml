<base:AvaloniaWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
        xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
        mc:Ignorable="d" 
        x:Class="Froststrap.UI.Elements.Bootstrapper.CustomDialog"
        Title="Froststrap"
        Width="800"
        Height="450"
        MinWidth="150"
        MinHeight="150"
        MaxWidth="1000"
        MaxHeight="1000"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:TitleBar
                x:Name="RootTitleBar"
                Title=""
                Grid.Row="0"
                Padding="8"
                ZIndex="1001"
                ShowClose="False"
                ShowMaximize="False"
                ShowMinimize="False" />

            <Grid x:Name="ElementGrid" Grid.Row="1" />
        </Grid>
    </Grid>
</base:AvaloniaWindow>