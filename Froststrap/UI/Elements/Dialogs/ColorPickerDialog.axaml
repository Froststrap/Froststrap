<base:AvaloniaWindow
     xmlns="https://github.com/avaloniaui"
     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     x:Class="Froststrap.UI.Elements.Dialogs.ColorPickerDialog"
     xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
     xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
     xmlns:colorPicker="clr-namespace:ColorPicker;assembly=ColorPicker.AvaloniaUI"
     Title="Color Picker"
     Width="400"
     SizeToContent="Height"
     CanResize="False"
     WindowStartupLocation="CenterOwner">

        <Grid RowDefinitions="Auto, *" Background="{DynamicResource ApplicationBackgroundColor}">
            <controls:TitleBar Grid.Row="0" 
                               Icon="avares://Froststrap/Froststrap.ico" 
                               Title="Select Color" />

            <StackPanel Grid.Row="1" Margin="20" Spacing="20">
                <Border CornerRadius="4" ClipToBounds="True">
                    <colorPicker:SquarePicker x:Name="Part_SquarePicker" 
                                             Height="220"
                                             HorizontalAlignment="Stretch"/>
                </Border>

                <StackPanel Spacing="8">
                    <TextBlock Text="Hex Code" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBox x:Name="Part_HexBox" 
                             Watermark="#RRGGBB"
                             VerticalContentAlignment="Center"
                             TextChanged="Part_HexBox_TextChanged"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Spacing="12" 
                            Margin="0,10,0,0">
                    <Button Content="Confirm" 
                            Width="100" 
                            Click="OnConfirm_Click" 
                            Classes="accent" />
                    <Button Content="Cancel" 
                            Width="100" 
                            Click="OnCancel_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
</base:AvaloniaWindow>