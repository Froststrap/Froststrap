<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ic="using:IconPacks.Avalonia.Material"
             xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             x:Class="Froststrap.UI.Elements.Settings.AccountSelectorView"
             x:DataType="vm:AccountSelectorViewModel"
             mc:Ignorable="d" d:DesignHeight="48" d:DesignWidth="220">

    <Grid Background="Transparent" HorizontalAlignment="Stretch">
        <!-- Current Account Button -->
        <Button Name="AccountButton"
                Background="Transparent" 
                BorderThickness="0"
                Padding="8,6"
                HorizontalAlignment="Stretch"
                Command="{Binding ToggleDropdownCommand}">
            <Button.Styles>
                <Style Selector="Button:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                </Style>
            </Button.Styles>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- Avatar Placeholder -->
                <Border Width="28" Height="28" CornerRadius="14" 
                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                    <Panel>
                        <ic:PackIconMaterial Kind="Account" 
                                            Width="16" Height="16"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding !CurrentAccountAvatarUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                        <Image Source="{Binding CurrentAccountAvatarUrl, Converter={StaticResource UrlToBitmapConverter}}" 
                               Stretch="UniformToFill"
                               IsVisible="{Binding CurrentAccountAvatarUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </Panel>
                </Border>

                <!-- Account Info -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Spacing="1" HorizontalAlignment="Stretch">
                    <TextBlock Text="{Binding CurrentAccount.Username, FallbackValue='Not Logged In'}" 
                              FontSize="11"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentAccount.DisplayName}" 
                              FontSize="9"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <!-- Account Dropdown Popup -->
        <Popup Name="AccountDropdown"
               IsOpen="{Binding IsDropdownOpen}" 
               Placement="Bottom"
               PlacementTarget="{Binding #AccountButton}"
               VerticalOffset="6"
               IsLightDismissEnabled="True">
            <Border MinWidth="260"
                    MaxHeight="420"
                    Background="#2D2D2D"
                    BorderBrush="{DynamicResource FrostBorderDefault}"
                    BorderThickness="1"
                    CornerRadius="6"
                    BoxShadow="0 8 32 0 #20000000">
                <Grid RowDefinitions="Auto,*">
                    <!-- Add Account Section -->
                    <Border Grid.Row="0" 
                           Padding="12,12,12,12"
                           Background="{DynamicResource ControlFillColorSecondaryBrush}"
                           BorderBrush="{DynamicResource FrostBorderDefault}"
                           BorderThickness="0,0,0,1">
                        <StackPanel Spacing="6">
                            <Button Content="Add Account"
                                   Command="{Binding AddAccountCommand}"
                                   IsEnabled="{Binding !IsAddingAccount}"
                                   Classes="FrostSubtle"
                                   Height="32"
                                   HorizontalAlignment="Stretch"/>

                            <ComboBox ItemsSource="{Binding AddMethods}"
                                     SelectedItem="{Binding SelectedAddMethod}"
                                     IsEnabled="{Binding !IsAddingAccount}"
                                     Height="32"
                                     HorizontalAlignment="Stretch"
                                     CornerRadius="6"
                                     BorderThickness="1"
                                     BorderBrush="{DynamicResource FrostBorderDefault}"/>
                        </StackPanel>
                    </Border>

                    <!-- Accounts List or Empty State -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" IsVisible="{Binding Accounts.Count}">
                        <ItemsControl ItemsSource="{Binding Accounts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="12,10,12,10"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding $parent[ItemsControl].((vm:AccountSelectorViewModel)DataContext).SelectAccountCommand}"
                                            CommandParameter="{Binding}">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                            </Style>
                                        </Button.Styles>
                                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                            <!-- Avatar -->
                                            <Border Grid.Column="0"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    ClipToBounds="True">
                                                <Panel>
                                                    <ic:PackIconMaterial Kind="Account"
                                                                        Width="16" Height="16"
                                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        IsVisible="{Binding AvatarUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                    <Image Source="{Binding AvatarUrl, Converter={StaticResource UrlToBitmapConverter}}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding AvatarUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </Panel>
                                            </Border>

                                            <!-- Name / username -->
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Username}"
                                                           FontSize="10"
                                                           Foreground="White"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Trash — right-aligned via Grid.Column="2" -->
                                            <controls:IconButton Grid.Column="2"
                                                                 Width="32" Height="32" Padding="4"
                                                                 VerticalAlignment="Center"
                                                                 Icon="TrashCanOutline"
                                                                 Classes="Danger"
                                                                 Command="{Binding $parent[ItemsControl].((vm:AccountSelectorViewModel)DataContext).DeleteAccountCommand}"
                                                                 CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <TextBlock Grid.Row="1"
                              Text="No accounts added&#xa;Click 'Add Account' above to get started"
                              FontSize="12"
                              TextAlignment="Center"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Padding="16,24"
                              IsVisible="{Binding !Accounts.Count}"/>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
