<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ic="using:IconPacks.Avalonia.Material"
             xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             x:Class="Froststrap.UI.Elements.Settings.AccountSelectorView"
             x:DataType="vm:AccountSelectorViewModel"
             mc:Ignorable="d" d:DesignHeight="48" d:DesignWidth="300">

    <Grid Background="Transparent">
        <!-- Current Account Button -->
        <Button Name="AccountButton"
                Background="Transparent" 
                BorderThickness="0"
                Padding="12,8"
                HorizontalAlignment="Stretch"
                Command="{Binding ToggleDropdownCommand}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <!-- Avatar Placeholder -->
                <Border Width="24" Height="24" CornerRadius="12" 
                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                    <ic:PackIconMaterial Kind="Account" 
                                        Width="14" Height="14"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding CurrentAccount, Converter={x:Static ObjectConverters.IsNull}}"/>
                </Border>

                <!-- Account Info -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding CurrentAccount.Username, FallbackValue='Select Account'}" 
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="{Binding CurrentAccount.DisplayName}" 
                              FontSize="10"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Chevron -->
                <ic:PackIconMaterial Kind="ChevronDown" 
                                    Width="16" Height="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,0"/>
            </StackPanel>
        </Button>

        <!-- Account Dropdown -->
        <Popup Name="AccountDropdown"
               IsOpen="{Binding IsDropdownOpen}" 
               Placement="Bottom"
               PlacementTarget="{Binding #AccountButton}"
               VerticalOffset="4"
               IsLightDismissEnabled="True">
            <Border MinWidth="280"
                    MaxHeight="400"
                    Background="{DynamicResource SukiSurfaceColor}"
                    BorderBrush="{DynamicResource FrostBorderDefault}"
                    BorderThickness="1"
                    CornerRadius="6"
                    BoxShadow="0 8 32 0 #20000000">
                <Grid RowDefinitions="Auto,Auto,*">
                    <!-- Add Account Bar -->
                    <Border Grid.Row="0" 
                           Padding="12,8"
                           Background="{DynamicResource ControlFillColorSecondaryBrush}"
                           BorderBrush="{DynamicResource FrostBorderDefault}"
                           BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <Button Grid.Column="0"
                                   Content="Add Account"
                                   Command="{Binding AddAccountCommand}"
                                   IsEnabled="{Binding !IsAddingAccount}"
                                   Classes="FrostSubtle"
                                   HorizontalAlignment="Stretch"
                                   Height="32"/>

                            <!-- Add Method ComboBox -->
                            <ComboBox Grid.Column="1"
                                     Margin="8,0,0,0"
                                     Width="120"
                                     ItemsSource="{Binding AddMethods}"
                                     SelectedItem="{Binding SelectedAddMethod}"
                                     IsEnabled="{Binding !IsAddingAccount}"/>
                        </Grid>
                    </Border>

                    <!-- Separator -->
                    <Separator Grid.Row="1" />

                    <!-- Accounts List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Accounts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Background="Transparent" Name="AccountItemGrid">
                                        <Button Background="Transparent"
                                               BorderThickness="0"
                                               Padding="12,10"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch"
                                               Name="AccountItemButton"
                                               Command="{Binding $parent[ItemsControl].((vm:AccountSelectorViewModel)DataContext).SelectAccountCommand}"
                                               CommandParameter="{Binding}">
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                </Style>
                                            </Button.Styles>
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0"
                                                       Width="32" Height="32" CornerRadius="16"
                                                       Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                    <ic:PackIconMaterial Kind="Account"
                                                                        Width="18" Height="18"
                                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding Username}"
                                                              FontSize="12"
                                                              FontWeight="SemiBold"
                                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                              FontSize="10"
                                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>

                                                <controls:IconButton Grid.Column="2"
                                                                   Width="28" Height="28" Padding="0"
                                                                   Icon="TrashCanOutline"
                                                                   Classes="Danger"
                                                                   Command="{Binding $parent[ItemsControl].((vm:AccountSelectorViewModel)DataContext).DeleteAccountCommand}"
                                                                   CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
