<base:AvaloniaWindow
	x:Class="Froststrap.UI.Elements.Settings.MainWindow"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
	xmlns:lucideAvalonia="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
	xmlns:resources="using:Froststrap.Resources"
	xmlns:ic="using:IconPacks.Avalonia.Material"
	xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
    xmlns:elements="clr-namespace:Froststrap.UI.Elements"
	xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
	xmlns:local="clr-namespace:Froststrap.UI.Elements.Settings"
	xmlns:models="using:Froststrap.Models"
	Title="{x:Static resources:Strings.Menu_Title}"
	Width="1125"
	Height="700"
	MinWidth="250"
	MinHeight="250"
	x:DataType="vm:MainWindowViewModel"
	CanResize="True"
	WindowStartupLocation="CenterScreen">

	<Grid RowDefinitions="48,*,56" ColumnDefinitions="220,*" Background="{DynamicResource ApplicationBackgroundColor}">
		<Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource ControlFillColorDefaultBrush}">
		   <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" >
				<Image
					Source="avares://Froststrap/Froststrap.ico"
                    Width="16" Height="16"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    RenderOptions.BitmapInterpolationMode="HighQuality" />
                <TextBlock Text="Froststrap Settings"
					VerticalAlignment="Center"
					Margin="10,0"
					FontSize="12"
					FontWeight="Normal"
					IsHitTestVisible="False" />
		   </StackPanel>
           <elements:SearchBar DataContext="{Binding SearchBar}" HorizontalAlignment="Center" VerticalAlignment="Center" />

			<StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Spacing="0" Margin="0,0,2,0">
				<controls:IconButton Name="PART_MinimizeButton" Classes="TitleBarButton" Icon="Minus" />
				<controls:IconButton Name="PART_MaximizeButton" Classes="TitleBarButton" Icon="SquareOutline" />
				<controls:IconButton Name="PART_CloseButton" Classes="TitleBarButton Close" Icon="Close" />
			</StackPanel>
		</Grid>

		<Border Name="SidebarBorder"
			BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
			Grid.Column="0"
			Grid.Row="1"
			BorderThickness="0,0,1,0"
			Background="{DynamicResource ControlFillColorDefaultBrush}">
			<Grid RowDefinitions="*,56">
				<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
					<StackPanel Spacing="12" Margin="8,0,8,0">
						<StackPanel Spacing="0">
							<TextBlock
								Text="MAIN"
								FontSize="11"
								FontWeight="SemiBold"
								Foreground="{DynamicResource TextFillColorTertiaryBrush}"
								Margin="10,8,10,4"
								Opacity="0.7" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToIntegrationsCommand}"
								Tag="integrations"
								Icon="Connection"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_Integrations_Title}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToBehaviourCommand}"
								Tag="behaviour"
								Icon="CogOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_Behaviour_Title}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToChannelsCommand}"
								Tag="channels"
								Icon="CloudArrowUp"
								IconSize="16"
								Content="{x:Static resources:Strings.Common_Deployment}" />
						</StackPanel>

						<StackPanel Spacing="0">
							<TextBlock
								Text="APPEARANCE"
								FontSize="11"
								FontWeight="SemiBold"
								Foreground="{DynamicResource TextFillColorTertiaryBrush}"
								Margin="10,8,10,4"
								Opacity="0.7" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToPresetModsCommand}"
								Tag="mods"
								Icon="PuzzleOutline"
								IconSize="16"
								Content="Preset Mods" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToAppearanceCommand}"
								Tag="appearance"
								Icon="PaletteOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_Appearance_Title}" />
						</StackPanel>

						<StackPanel Spacing="0">
							<TextBlock
								Text="ROBLOX TWEAKS"
								FontSize="11"
								FontWeight="SemiBold"
								Foreground="{DynamicResource TextFillColorTertiaryBrush}"
								Margin="10,8,10,4"
								Opacity="0.7" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToFastFlagsCommand}"
								Tag="fastflags"
								Icon="FlagOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_FastFlags_Title}" />

							<controls:IconButton
								Name="gbs"
								Classes="nav-button"
								Command="{Binding NavigateToGlobalSettingsCommand}"
								Tag="globalsettings"
								Icon="SquareEditOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_GlobalSettings_Title}" />
						</StackPanel>

						<StackPanel Spacing="0">
							<TextBlock
								Text="MISC"
								FontSize="11"
								FontWeight="SemiBold"
								Foreground="{DynamicResource TextFillColorTertiaryBrush}"
								Margin="10,8,10,4"
								Opacity="0.7" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToRegionSelectorCommand}"
								Tag="regionselector"
								Icon="Earth"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_RegionSelector_Title}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToShortcutsCommand}"
								Tag="shortcuts"
								Icon="LinkBoxOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Common_Shortcuts}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding OpenAboutCommand}"
								Icon="InformationOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_About_Title}" />
						</StackPanel>
					</StackPanel>
				</ScrollViewer>
			</Grid>
		</Border>

		<Grid Grid.Column="1" Grid.Row="1" RowDefinitions="Auto,*">
			<Border
				Grid.Row="0"
				Padding="24,24,24,16"
				BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
				BorderThickness="0,0,0,1">
				<StackPanel>
					<ItemsControl
						ItemsSource="{Binding BreadcrumbItems}"
						Margin="0,0,0,10"
						IsVisible="{Binding HasBreadcrumbs}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate DataType="vm:BreadcrumbItemModel">
								<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
									<Button
										Content="{Binding Content}"
										Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BreadcrumbItemClickedCommand}"
										CommandParameter="{Binding}"
										Background="Transparent"
										BorderThickness="0"
										Foreground="{DynamicResource TextFillColorPrimaryBrush}"
										FontSize="20"
										FontWeight="SemiBold"
										Padding="0"
										IsVisible="{Binding !IsLast}" />
									<TextBlock
										Text="›"
										VerticalAlignment="Center"
										FontSize="20"
										Foreground="{DynamicResource TextFillColorSecondaryBrush}"
										IsVisible="{Binding !IsLast}" />
									<TextBlock
										Text="{Binding Content}"
										VerticalAlignment="Center"
										FontSize="20"
										FontWeight="SemiBold"
										Foreground="{DynamicResource TextFillColorPrimaryBrush}"
										IsVisible="{Binding IsLast}" />
								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<TextBlock
						x:Name="PageTitleText"
						FontSize="20"
						FontWeight="SemiBold"
						Margin="0,0,0,4"
						Foreground="{DynamicResource TextFillColorPrimaryBrush}"
						Text="{Binding CurrentPageTitle}"
						IsVisible="{Binding ShowPageTitle}" />

					<controls:MarkdownTextBlock
						x:Name="PageDescriptionText"
						FontSize="13"
						Foreground="{DynamicResource TextFillColorSecondaryBrush}"
						MarkdownText="{Binding CurrentPageDescription}"
						Margin="0,0,0,2"
						IsVisible="{Binding CurrentPageDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

					<ui:InfoBar x:Name="AlertBar" Margin="0,8,0,0" Severity="Warning" IsVisible="False" />
				</StackPanel>
			</Border>

			<Panel Grid.Row="1">
				<Panel Name="NotificationPanel"
					HorizontalAlignment="Center"
					VerticalAlignment="Bottom"
					Margin="0,0,0,15"
					MaxWidth="450"
					ZIndex="1000" />

				<TransitioningContentControl
					x:Name="PageContentControl"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch" />
			</Panel>
		</Grid>

		<Border
			Grid.Row="2"
			Grid.ColumnSpan="2"
			Height="56"
			Padding="0,0,16,0"
			BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
			BorderThickness="0,1,0,0">
			<Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto"
				ColumnSpacing="8">
				<local:AccountSelectorView x:Name="AccountSelectorView" Grid.Column="0" Margin="8,0,0,0" />
				<Button Grid.Column="2"
					Classes="accent"
					Height="36"
					Padding="20,0"
					Command="{Binding SaveAndLaunchSettingsCommand}"
					Content="{x:Static resources:Strings.Menu_SaveAndLaunch}" />
				<Button Grid.Column="3"
					Classes="accent"
					Height="36"
					Padding="20,0"
					Command="{Binding RestartAppCommand}"
					Content="{x:Static resources:Strings.Menu_Restart}" />
				<Button Grid.Column="4"
					Classes="accent"
					Height="36"
					Padding="20,0"
					Command="{Binding SaveSettingsCommand}"
					Content="{x:Static resources:Strings.Menu_Save}" />
				<Button Grid.Column="5"
					Height="36"
					Padding="20,0"
					Command="{Binding CloseWindowCommand}"
					Content="{x:Static resources:Strings.Common_Close}" />
			</Grid>
		</Border>

		<Border
			x:Name="OffscreenIndexingCanvas"
			Grid.Row="1"
			Grid.Column="1"
			Width="905"
			Height="700"
			Opacity="0"
			IsHitTestVisible="False"
			IsVisible="False"
			ZIndex="-1000" />
	</Grid>
</base:AvaloniaWindow>