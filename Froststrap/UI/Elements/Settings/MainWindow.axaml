<base:AvaloniaWindow
	x:Class="Froststrap.UI.Elements.Settings.MainWindow"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
	xmlns:lucideAvalonia="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
	xmlns:resources="using:Froststrap.Resources"
	xmlns:ic="using:IconPacks.Avalonia.Material"
	xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
	xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
	xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
	Title="{x:Static resources:Strings.Menu_Title}"
	Width="1125"
	Height="700"
	MinWidth="250"
	MinHeight="250"
	x:DataType="vm:MainWindowViewModel"
	CanResize="True"
	WindowStartupLocation="CenterScreen">

	<Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource ApplicationBackgroundColor}">

		<controls:TitleBar
			Title="{x:Static resources:Strings.Menu_Title}"
			Icon="avares://Froststrap/Froststrap.ico"
			Grid.Row="0"
			Height="32"
			Background="{DynamicResource FrostSidebarBackground}" />

		<Panel
			Name="NotificationPanel"
			Grid.Row="1"
			HorizontalAlignment="Center"
			VerticalAlignment="Bottom"
			Margin="0,0,0,15"
			MaxWidth="450"
			ZIndex="1000" />

		<Grid Name="MainGrid" Grid.Row="1" ColumnDefinitions="220,*">

			<Border
				Grid.Column="0"
				Background="{DynamicResource FrostSidebarBackground}"
				BorderBrush="{DynamicResource FrostBorderDefault}"
				BorderThickness="0,0,1,0">

				<Grid RowDefinitions="*,Auto">

					<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
						<StackPanel Spacing="0" Margin="8,6,8,0">

							<!-- Section label: Main -->
							<TextBlock
								Text="MAIN"
								FontSize="11"
								FontWeight="SemiBold"
								Foreground="{DynamicResource TextFillColorTertiaryBrush}"
								Margin="10,8,10,4"
								Opacity="0.7" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToIntegrationsCommand}"
								Tag="integrations"
								Icon="Connection"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_Integrations_Title}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToBehaviourCommand}"
								Tag="behaviour"
								Icon="CogOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_Behaviour_Title}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToPresetModsCommand}"
								Tag="mods"
								Icon="PuzzleOutline"
								IconSize="16"
								Content="Preset Mods" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToFastFlagsCommand}"
								Tag="fastflags"
								Icon="FlagOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_FastFlags_Title}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToAppearanceCommand}"
								Tag="appearance"
								Icon="PaletteOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_Appearance_Title}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToRegionSelectorCommand}"
								Tag="regionselector"
								Icon="Earth"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_RegionSelector_Title}" />

							<controls:IconButton
								Name="gbs"
								Classes="nav-button"
								Command="{Binding NavigateToGlobalSettingsCommand}"
								Tag="globalsettings"
								Icon="SquareEditOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Menu_GlobalSettings_Title}" />

							<controls:IconButton
								Classes="nav-button"
								Command="{Binding NavigateToShortcutsCommand}"
								Tag="shortcuts"
								Icon="LinkBoxOutline"
								IconSize="16"
								Content="{x:Static resources:Strings.Common_Shortcuts}" />

						</StackPanel>
					</ScrollViewer>

					<StackPanel Grid.Row="1" Spacing="0" Margin="8,0,8,8">
						<Separator
							Margin="2,6"
							Background="{DynamicResource FrostBorderDefault}"
							Height="1" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding OpenAccountManagerCommand}"
							Icon="AccountMultipleOutline"
							IconSize="16"
							Content="{x:Static resources:Strings.Menu_AccountManager_Title}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToChannelsCommand}"
							Tag="channels"
							Icon="TuneVertical"
							IconSize="16"
							Content="{x:Static resources:Strings.Common_Settings}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding OpenAboutCommand}"
							Icon="InformationOutline"
							IconSize="16"
							Content="{x:Static resources:Strings.Menu_About_Title}" />
					</StackPanel>

				</Grid>
			</Border>

			<Grid Grid.Column="1" RowDefinitions="Auto,*">

				<Border
					Grid.Row="0"
					Padding="24,24,24,16"
					Background="{DynamicResource LayerFillColorAltBrush}"
					BorderBrush="{DynamicResource FrostBorderDefault}"
					BorderThickness="0,0,0,1">
					<StackPanel>
						<ItemsControl
							ItemsSource="{Binding BreadcrumbItems}"
							Margin="0,0,0,10"
							IsVisible="{Binding HasBreadcrumbs}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate DataType="vm:BreadcrumbItemModel">
									<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
										<Button
											Content="{Binding Content}"
											Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BreadcrumbItemClickedCommand}"
											CommandParameter="{Binding}"
											Background="Transparent"
											BorderThickness="0"
											Foreground="{DynamicResource TextFillColorPrimaryBrush}"
											FontSize="20"
											FontWeight="SemiBold"
											Padding="0"
											IsVisible="{Binding !IsLast}" />
										<TextBlock
											Text="›"
											VerticalAlignment="Center"
											FontSize="20"
											Foreground="{DynamicResource TextFillColorSecondaryBrush}"
											IsVisible="{Binding !IsLast}" />
										<TextBlock
											Text="{Binding Content}"
											VerticalAlignment="Center"
											FontSize="20"
											FontWeight="SemiBold"
											Foreground="{DynamicResource TextFillColorPrimaryBrush}"
											IsVisible="{Binding IsLast}" />
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<TextBlock
							x:Name="PageTitleText"
							FontSize="20"
							FontWeight="SemiBold"
							Margin="0,0,0,4"
							Foreground="{DynamicResource TextFillColorPrimaryBrush}"
							Text="{Binding CurrentPageTitle}"
							IsVisible="{Binding ShowPageTitle}" />

						<controls:MarkdownTextBlock
							x:Name="PageDescriptionText"
							FontSize="13"
							Foreground="{DynamicResource TextFillColorSecondaryBrush}"
							MarkdownText="{Binding CurrentPageDescription}"
							Margin="0,0,0,2"
							IsVisible="{Binding CurrentPageDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

						<suki:InfoBar x:Name="AlertBar" Grid.Row="0" Margin="0,8,0,0" Severity="Warning" IsVisible="False" />
					</StackPanel>
				</Border>

				<TransitioningContentControl
					x:Name="PageContentControl"
					Grid.Row="1"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					Background="{DynamicResource ApplicationBackgroundColor}" />
			</Grid>
		</Grid>

		<Border
			Grid.Row="2"
			Height="56"
			Padding="16,0"
			Background="{DynamicResource FrostSidebarBackground}"
			BorderBrush="{DynamicResource FrostBorderDefault}"
			BorderThickness="0,1,0,0">
			<Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">

				<StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="10">
					<ToggleSwitch
						IsChecked="{Binding TestModeEnabled, Mode=TwoWay}"
						OffContent=""
						OnContent="" />
					<TextBlock
						VerticalAlignment="Center"
						FontSize="14"
						Foreground="{DynamicResource TextFillColorSecondaryBrush}"
						Text="{x:Static resources:Strings.Menu_TestMode}" />
				</StackPanel>

				<StackPanel
					Grid.Column="1"
					Grid.ColumnSpan="4"
					Orientation="Horizontal"
					Spacing="8">

					<Button
                        Classes="FrostSidebarAccent"
						Height="36"
						Padding="20,0"
						Command="{Binding SaveAndLaunchSettingsCommand}"
						Content="{x:Static resources:Strings.Menu_SaveAndLaunch}" />

					<Button
                        Classes="FrostSidebarAccent"
						Height="36"
						Padding="20,0"
						Command="{Binding RestartAppCommand}"
						Content="{x:Static resources:Strings.Menu_Restart}" />

					<Button
                        Classes="FrostSidebarAccent"
						Height="36"
						Padding="20,0"
						Command="{Binding SaveSettingsCommand}"
						Content="{x:Static resources:Strings.Menu_Save}" />

					<Button
						Classes="FrostSubtle"
						Height="36"
						Padding="20,0"
						Command="{Binding CloseWindowCommand}"
						Content="{x:Static resources:Strings.Common_Close}" />

				</StackPanel>
			</Grid>
		</Border>

	</Grid>
</base:AvaloniaWindow>
