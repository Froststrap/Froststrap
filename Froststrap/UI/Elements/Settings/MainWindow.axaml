<base:AvaloniaWindow
	x:Class="Froststrap.UI.Elements.Settings.MainWindow"
	x:DataType="vm:MainWindowViewModel"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:resources="using:Froststrap.Resources"
	xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
	xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
	xmlns:lucideAvalonia="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
	Title="{x:Static resources:Strings.Menu_Title}"
	Width="1125" Height="700"

	MinWidth="250" MinHeight="250"
	WindowStartupLocation="CenterScreen"
	ExtendClientAreaToDecorationsHint="True"
	ExtendClientAreaTitleBarHeightHint="-1"
	TransparencyLevelHint="Mica"
	Background="Transparent">

	<Grid RowDefinitions="Auto,*,Auto">

		<TitleBar Grid.Row="0" Height="32" Background="{DynamicResource LayerFillColorDefaultBrush}" />

		<Panel Grid.Row="1" Name="NotificationPanel" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0" ZIndex="1000" />

		<!-- Main Navigation and Content -->
		<Grid Grid.Row="1" ColumnDefinitions="64,*">
			<Border Grid.Column="0" Background="{DynamicResource LayerFillColorDefaultBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
				<ScrollViewer VerticalScrollBarVisibility="Hidden">
					<StackPanel Spacing="0" VerticalAlignment="Top">
					<Button 
						ToolTip.Tip="{x:Static resources:Strings.Menu_Integrations_Title}"
						Command="{Binding NavigateToIntegrationsCommand}"
						Tag="integrations"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Plus" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Button 
						ToolTip.Tip="{x:Static resources:Strings.Menu_Behaviour_Title}"
						Command="{Binding NavigateToBehaviourCommand}"
						Tag="behaviour"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Settings" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Button 
						ToolTip.Tip="{x:Static resources:Strings.Menu_Mods_Title}"
						Command="{Binding NavigateToModsCommand}"
						Tag="mods"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Wrench" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Button 
						ToolTip.Tip="Community Mods"
						Command="{Binding NavigateToCommunityModsCommand}"
						Tag="communitymods"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Package" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Button 
						ToolTip.Tip="{x:Static resources:Strings.Menu_FastFlags_Title}"
						Command="{Binding NavigateToFastFlagsCommand}"
						Tag="fastflags"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Flag" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Button 
						ToolTip.Tip="{x:Static resources:Strings.Menu_Appearance_Title}"
						Command="{Binding NavigateToAppearanceCommand}"
						Tag="appearance"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Palette" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Button 
						ToolTip.Tip="{x:Static resources:Strings.Menu_RobloxSettings_Title}"
						Command="{Binding NavigateToRobloxSettingsCommand}"
						Tag="robloxsettings"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Gauge" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Separator Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

					<!-- Footer Menu Items -->
					<Button 
						ToolTip.Tip="{x:Static resources:Strings.Menu_AccountManager_Title}"
						Command="{Binding OpenAccountManagerCommand}"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Users" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Button 
						ToolTip.Tip="{x:Static resources:Strings.Common_Settings}"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Zap" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>

					<Button 
						ToolTip.Tip="About Me"
						Command="{Binding OpenAboutCommand}"
						Classes="icon-button">
						<lucideAvalonia:Lucide Icon="Info" StrokeBrush="#888888" StrokeThickness="1.5" Width="16" Height="16" />
					</Button>
						</StackPanel>
					</ScrollViewer>
				</Border>

				<Grid Grid.Column="1" RowDefinitions="Auto,*">
				<Border Grid.Row="0" Padding="12" Background="{DynamicResource LayerFillColorAltBrush}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
					<TextBlock x:Name="AlertText" Text="" Foreground="{DynamicResource SystemAccentColor}" FontSize="13" />
				</Border>

				<TransitioningContentControl 
					x:Name="PageContentControl"
					Grid.Row="1"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					Background="{DynamicResource LayerFillColorDefaultBrush}" />
			</Grid>
		</Grid>

		<Grid x:Name="LoadingOverlay" Grid.Row="1" Grid.RowSpan="2" Background="#A0000000" IsVisible="False" ZIndex="999">
			<Border Background="{DynamicResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
				<StackPanel Spacing="15">
					<TextBlock x:Name="LoadingOverlayText" Text="Loading..." FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
					<ProgressBar IsIndeterminate="True" Width="50" Height="4" Foreground="{DynamicResource SystemAccentColor}" />
				</StackPanel>
			</Border>
		</Grid>

		<Border Grid.Row="2" Padding="12" Background="{DynamicResource LayerFillColorDefaultBrush}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
			<Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<ToggleSwitch IsChecked="{Binding TestModeEnabled, Mode=TwoWay}" OnContent="" OffContent="" />
					<TextBlock Text="{x:Static resources:Strings.Menu_TestMode}" VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
				</StackPanel>

				<StackPanel Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="8">
					<Button Content="{x:Static resources:Strings.Menu_SaveAndLaunch}" Classes="accent" Command="{Binding SaveAndLaunchSettingsCommand}" Background="{DynamicResource SystemAccentColor}" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
					<Button Content="{x:Static resources:Strings.Menu_Restart}" Classes="accent" Command="{Binding RestartAppCommand}" Background="{DynamicResource SystemAccentColor}" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
					<Button Content="{x:Static resources:Strings.Menu_Save}" Classes="accent" Command="{Binding SaveSettingsCommand}" Background="{DynamicResource SystemAccentColor}" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
					<Button Content="{x:Static resources:Strings.Common_Close}" Command="{Binding CloseWindowCommand}" Background="{DynamicResource LayerFillColorAltBrush}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</base:AvaloniaWindow>