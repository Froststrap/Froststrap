<base:AvaloniaWindow
	x:Class="Froststrap.UI.Elements.Settings.MainWindow"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
	xmlns:lucideAvalonia="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
	xmlns:resources="using:Froststrap.Resources"
	xmlns:ic="using:IconPacks.Avalonia.Material"
	xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
	xmlns:ui="using:FluentAvalonia.UI.Controls"
	xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
	Title="{x:Static resources:Strings.Menu_Title}"
	Width="1125"
	Height="700"
	MinWidth="250"
	MinHeight="250"
	x:DataType="vm:MainWindowViewModel"
	SystemDecorations="None"
	ExtendClientAreaTitleBarHeightHint="-1"
	ExtendClientAreaToDecorationsHint="True"
	WindowStartupLocation="CenterScreen">

	<Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource ApplicationBackgroundColor}">

		<controls:TitleBar
			Title="{x:Static resources:Strings.Menu_Title}"
			Icon="avares://Froststrap/Froststrap.ico"
			Grid.Row="0"
			Height="32"
			Background="{DynamicResource LayerFillColorDefaultBrush}" />

		<Panel
			Name="NotificationPanel"
			Grid.Row="1"
			HorizontalAlignment="Center"
			VerticalAlignment="Bottom"
			Margin="0,0,0,15"
			MaxWidth="450"
			ZIndex="1000" />

		<!--  Main Navigation and Content  -->
		<Grid
			Name="MainGrid"
			Grid.Row="1"
			ColumnDefinitions="64,*">
			<Border
				Grid.Column="0"
				Background="{DynamicResource LayerFillColorDefaultBrush}"
				BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
				BorderThickness="0,0,1,0">
				<ScrollViewer VerticalScrollBarVisibility="Hidden">
					<StackPanel VerticalAlignment="Top" Spacing="0">
<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToIntegrationsCommand}"
							Tag="integrations"
							Icon="Plus"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Menu_Integrations_Title}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToBehaviourCommand}"
							Tag="behaviour"
							Icon="CogOutline"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Menu_Behaviour_Title}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToModsCommand}"
							Tag="mods"
							Icon="PuzzleOutline"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Menu_Mods_Title}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToFastFlagsCommand}"
							Tag="fastflags"
							Icon="FlagOutline"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Menu_FastFlags_Title}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToAppearanceCommand}"
							Tag="appearance"
							Icon="PaletteOutline"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Menu_Appearance_Title}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToRegionSelectorCommand}"
							Tag="regionselector"
							Icon="Earth"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Menu_RegionSelector_Title}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToGlobalSettingsCommand}"
							Tag="globalsettings"
							Icon="SquareEditOutline"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Menu_GlobalSettings_Title}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding NavigateToShortcutsCommand}"
							Tag="shortcuts"
							Icon="LinkBoxOutline"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Common_Shortcuts}" />

						<Separator Margin="0,8" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding OpenAccountManagerCommand}"
							Icon="AccountMultipleOutline"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Menu_AccountManager_Title}" />

						<controls:IconButton 
							Classes="nav-button"
							Command="{Binding NavigateToChannelsCommand}"
							Tag="channels"
							Icon="CogOutline"
							IconSize="24"
							ToolTip.Tip="{x:Static resources:Strings.Common_Settings}" />

						<controls:IconButton
							Classes="nav-button"
							Command="{Binding OpenAboutCommand}"
							Icon="InformationOutline"
							IconSize="24"
							ToolTip.Tip="About Me" />
					</StackPanel>
				</ScrollViewer>
			</Border>

			<Grid Grid.Column="1" RowDefinitions="Auto,*">
				<Border
					Grid.Row="0"
					Padding="20,24,20,8"
					Background="{DynamicResource LayerFillColorAltBrush}"
					BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
					BorderThickness="0,0,0,1">
					<StackPanel>
						<ItemsControl
							ItemsSource="{Binding BreadcrumbItems}"
							Margin="0,0,0,12"
							IsVisible="{Binding HasBreadcrumbs}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate DataType="vm:BreadcrumbItemModel">
									<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
										<Button
											Content="{Binding Content}"
											Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BreadcrumbItemClickedCommand}"
											CommandParameter="{Binding}"
											Background="Transparent"
											BorderThickness="0"
											Foreground="{DynamicResource TextFillColorPrimaryBrush}"
											FontSize="24"
											FontWeight="SemiBold"
											Padding="0"
											IsVisible="{Binding !IsLast}" />
										<TextBlock
											Text=">"
											VerticalAlignment="Center"
											FontSize="24"
											FontWeight="SemiBold"
											Foreground="{DynamicResource TextFillColorSecondaryBrush}"
											IsVisible="{Binding !IsLast}" />
										<TextBlock
											Text="{Binding Content}"
											VerticalAlignment="Center"
											FontSize="24"
											FontWeight="SemiBold"
											Foreground="{DynamicResource TextFillColorPrimaryBrush}"
											IsVisible="{Binding IsLast}" />
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<TextBlock
							x:Name="PageTitleText"
							FontSize="24"
							FontWeight="SemiBold"
							Margin="0,0,0,12"
							Foreground="{DynamicResource TextFillColorPrimaryBrush}"
							Text="{Binding CurrentPageTitle}"
							IsVisible="{Binding ShowPageTitle}" />

						<controls:MarkdownTextBlock
							x:Name="PageDescriptionText"
							FontSize="13"
							Foreground="{DynamicResource TextFillColorSecondaryBrush}"
							MarkdownText="{Binding CurrentPageDescription}"
							Margin="0,0,0,4"
							IsVisible="{Binding CurrentPageDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

						<ui:InfoBar x:Name="AlertBar" Grid.Row="0" Margin="0,8,0,4" IsOpen="True" Message="FluentAvalonia so w lowkey" Severity="Warning" IsVisible="False" IsClosable="False" />
					</StackPanel>
				</Border>

				<TransitioningContentControl
					x:Name="PageContentControl"
					Grid.Row="1"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					Background="{DynamicResource LayerFillColorDefaultBrush}" />
			</Grid>
		</Grid>

		<Border
			Grid.Row="2"
			Padding="12"
			Background="{DynamicResource LayerFillColorDefaultBrush}"
			BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
			BorderThickness="0,1,0,0">
			<Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
				<StackPanel VerticalAlignment="Center" Orientation="Horizontal">
					<ToggleSwitch
						IsChecked="{Binding TestModeEnabled, Mode=TwoWay}"
						OffContent=""
						OnContent="" />
					<TextBlock
						Margin="8,0,0,0"
						VerticalAlignment="Center"
						FontWeight="Medium"
						Foreground="{DynamicResource TextFillColorSecondaryBrush}"
						Text="{x:Static resources:Strings.Menu_TestMode}" />
				</StackPanel>

				<StackPanel
					Grid.Column="1"
					Grid.ColumnSpan="4"
					Orientation="Horizontal"
					Spacing="8">
					<Button
						Background="{DynamicResource SystemAccentColor}"
						Classes="accent"
						Command="{Binding SaveAndLaunchSettingsCommand}"
						Content="{x:Static resources:Strings.Menu_SaveAndLaunch}"
						Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
					<Button
						Background="{DynamicResource SystemAccentColor}"
						Classes="accent"
						Command="{Binding RestartAppCommand}"
						Content="{x:Static resources:Strings.Menu_Restart}"
						Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
					<Button
						Background="{DynamicResource SystemAccentColor}"
						Classes="accent"
						Command="{Binding SaveSettingsCommand}"
						Content="{x:Static resources:Strings.Menu_Save}"
						Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
					<Button
						Background="{DynamicResource LayerFillColorAltBrush}"
						Command="{Binding CloseWindowCommand}"
						Content="{x:Static resources:Strings.Common_Close}"
						Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</base:AvaloniaWindow>
