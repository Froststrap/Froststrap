<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
        xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls">

    <Style Selector="controls|SquareCard">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource SukiBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="12" />

        <Setter Property="Template">
            <ControlTemplate>
                <suki:GlassCard Name="PART_RootCard"
                                IsInteractive="True"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,6,6,6">

                    <Grid MinHeight="140" RowDefinitions="Auto,Auto,*">
                        <TextBlock Grid.Row="0"
                                   FontSize="18"
                                   FontWeight="Medium"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SukiText}"
                                   Text="{TemplateBinding Header}"
                                   IsVisible="{TemplateBinding Header, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <controls:MarkdownTextBlock Grid.Row="1"
                                              FontSize="13"
                                              Opacity="0.7"
                                              TextWrapping="Wrap"
                                              Margin="0,6,0,0"
                                              Foreground="{DynamicResource SukiText}"
                                              MarkdownText="{TemplateBinding Description}"
                                              IsVisible="{TemplateBinding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <ContentPresenter Grid.Row="2"
                                          Content="{TemplateBinding InnerContent}"
                                          VerticalAlignment="Bottom"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,12,0,0"/>
                    </Grid>
                </suki:GlassCard>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|SquareCard:pointerover /template/ suki|GlassCard#PART_RootCard">
        <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor}" />
    </Style>
</Styles>