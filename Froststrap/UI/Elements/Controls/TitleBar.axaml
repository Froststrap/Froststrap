<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
        xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls">

    <Style Selector="controls|TitleBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Height" Value="40" /> <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="Auto, *, Auto" 
                      Height="{TemplateBinding Height}" 
                      Background="{TemplateBinding Background}">

                    <Image Grid.Column="0"
                           Source="{TemplateBinding Icon}"
                           Width="20" Height="20"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           RenderOptions.BitmapInterpolationMode="HighQuality" />

                    <Panel Name="PART_DragLayer" Grid.Column="1" Background="Transparent">
                        <TextBlock Text="{TemplateBinding Title}"
                                   VerticalAlignment="Center"
                                   Margin="12,0"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   IsHitTestVisible="False"
                                   Foreground="{DynamicResource SukiText}" />
                    </Panel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                        <controls:IconButton Name="PART_MinimizeButton" 
                                           Classes="TitleBarButton" 
                                           Icon="Minus" 
                                           IsVisible="{TemplateBinding ShowMinimize}"/>

                        <controls:IconButton Name="PART_MaximizeButton" 
                                           Classes="TitleBarButton" 
                                           IsVisible="{TemplateBinding ShowMaximize}" 
                                           Icon="SquareOutline"/>

                        <controls:IconButton Name="PART_CloseButton" 
                                           Classes="TitleBarButton Close" 
                                           Icon="Close" 
                                           IsVisible="{TemplateBinding ShowClose}"/>
                    </StackPanel>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|IconButton.TitleBarButton">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
    </Style>

    <Style Selector="controls|IconButton.TitleBarButton:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource SukiAccentColor10}" />
    </Style>

    <Style Selector="controls|IconButton.TitleBarButton.Close:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#C42B1C" /> </Style>

    <Style Selector="controls|IconButton.TitleBarButton.Close:pointerover">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="controls|IconButton.TitleBarButton:disabled">
        <Setter Property="Opacity" Value="0.2" />
    </Style>

</Styles>