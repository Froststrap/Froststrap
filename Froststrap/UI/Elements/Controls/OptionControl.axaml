<Styles xmlns="https://github.com/avaloniaui"
		xmlns:resources="clr-namespace:Froststrap.Resources"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:ic="using:IconPacks.Avalonia.Material"
		xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

	<Design.PreviewWith>
		<Border Background="{DynamicResource ApplicationBackgroundColor}" Padding="40" MinWidth="600" MinHeight="500">
			<StackPanel Spacing="16">
				<TextBlock Text="OptionControl Previews" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

				<!-- With ToggleSwitch and description -->
				<controls:OptionControl 
					Header="Enable Feature" 
					Description="This setting controls an important feature. Enable it carefully.">
					<ToggleSwitch IsChecked="True" />
				</controls:OptionControl>

				<!-- With description only -->
				<controls:OptionControl 
					Header="Another Setting" 
					Description="This is a setting with a description to explain what it does.">
					<TextBlock Text="Value" />
				</controls:OptionControl>

				<!-- Without description -->
				<controls:OptionControl 
					Header="Simple Setting">
					<ComboBox Width="150" SelectedIndex="0">
						<ComboBoxItem>Option A</ComboBoxItem>
						<ComboBoxItem>Option B</ComboBoxItem>
						<ComboBoxItem>Option C</ComboBoxItem>
					</ComboBox>
				</controls:OptionControl>

				<!-- With help link -->
				<controls:OptionControl 
					Header="Setting with Help" 
					Description="Hover over the help icon for more information."
					HelpLink="https://example.com">
					<ToggleSwitch />
				</controls:OptionControl>

				<!-- Disabled state -->
				<controls:OptionControl 
					Header="Disabled Setting" 
					Description="This setting is currently disabled."
					IsEnabled="False">
					<ToggleSwitch />
				</controls:OptionControl>
			</StackPanel>
		</Border>
	</Design.PreviewWith>
</Styles>