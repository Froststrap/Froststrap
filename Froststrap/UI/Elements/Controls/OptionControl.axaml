<Styles xmlns="https://github.com/avaloniaui"
		xmlns:resources="clr-namespace:Froststrap.Resources"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:ic="using:IconPacks.Avalonia.Material"
		xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

	<Design.PreviewWith>
		<Border Background="{DynamicResource ApplicationBackgroundColor}" Padding="40" MinWidth="600" MinHeight="500">
			<StackPanel Spacing="16">
				<TextBlock Text="OptionControl Previews" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

				<!-- With ToggleSwitch and description -->
				<controls:OptionControl 
					Header="Enable Feature" 
					Description="This setting controls an important feature. Enable it carefully.">
					<ToggleSwitch IsChecked="True" />
				</controls:OptionControl>

				<!-- With description only -->
				<controls:OptionControl 
					Header="Another Setting" 
					Description="This is a setting with a description to explain what it does.">
					<TextBlock Text="Value" />
				</controls:OptionControl>

				<!-- Without description -->
				<controls:OptionControl 
					Header="Simple Setting">
					<ComboBox Width="150" SelectedIndex="0">
						<ComboBoxItem>Option A</ComboBoxItem>
						<ComboBoxItem>Option B</ComboBoxItem>
						<ComboBoxItem>Option C</ComboBoxItem>
					</ComboBox>
				</controls:OptionControl>

				<!-- With help link -->
				<controls:OptionControl 
					Header="Setting with Help" 
					Description="Hover over the help icon for more information."
					HelpLink="https://example.com">
					<ToggleSwitch />
				</controls:OptionControl>

				<!-- Disabled state -->
				<controls:OptionControl 
					Header="Disabled Setting" 
					Description="This setting is currently disabled."
					IsEnabled="False">
					<ToggleSwitch />
				</controls:OptionControl>
			</StackPanel>
		</Border>
	</Design.PreviewWith>

	<Style Selector="controls|OptionControl">
		<Setter Property="Background"      Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
		<Setter Property="BorderBrush"     Value="{DynamicResource FrostBorderDefault}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="Padding"         Value="16,12" />
		<Setter Property="Template">
			<ControlTemplate>
				<Border Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						Padding="{TemplateBinding Padding}"
						CornerRadius="6"
						MinHeight="64"
						Margin="0,2">
					<Grid ColumnDefinitions="*,Auto">
						<StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="3">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<!-- Header: 14px SemiBold for WCAG readability -->
								<TextBlock
									Text="{TemplateBinding Header}"
									FontSize="14"
									FontWeight="SemiBold"
									VerticalAlignment="Center"
									Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

								<!-- Help link icon -->
								<controls:Hyperlink
									Url="{TemplateBinding HelpLink}"
									Margin="0,1,0,0"
									VerticalAlignment="Center"
									ClipToBounds="False"
									IsVisible="{TemplateBinding HelpLink, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
									ToolTip.Tip="{x:Static resources:Strings.Menu_MoreInfo}">
									<ic:PackIconMaterial
										Name="HelpIcon"
										Width="16" Height="16"
										Kind="HelpCircleOutline"
										Opacity="0.6">
										<ic:PackIconMaterial.Transitions>
											<Transitions>
												<DoubleTransition Property="Opacity" Duration="0:0:0.2" />
											</Transitions>
										</ic:PackIconMaterial.Transitions>
									</ic:PackIconMaterial>
								</controls:Hyperlink>
							</StackPanel>

							<!-- Description: 12px regular secondary, visible only when set -->
							<controls:MarkdownTextBlock
								MarkdownText="{TemplateBinding Description}"
								FontSize="12"
								Foreground="{DynamicResource TextFillColorSecondaryBrush}"
								TextWrapping="Wrap"
								IsVisible="{TemplateBinding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
						</StackPanel>

						<!-- Control slot (toggle, combobox, etc.) -->
						<ContentPresenter
							Grid.Column="1"
							Content="{TemplateBinding InnerContent}"
							VerticalAlignment="Center"
							HorizontalAlignment="Right"
							Margin="16,0,0,0" />
					</Grid>
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>

	<Style Selector="controls|OptionControl:pointerover">
		<Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
	</Style>
</Styles>