<base:AvaloniaWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:Froststrap.UI.Elements.About.Pages"
        xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
        xmlns:resources="clr-namespace:Froststrap.Resources"
        xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.About"
        xmlns:ic="using:IconPacks.Avalonia.Material"
        mc:Ignorable="d"
        x:Class="Froststrap.UI.Elements.About.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{x:Static resources:Strings.About_Title}"
        MinWidth="740" Width="740" Height="440"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Mica"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True">

  <Grid RowDefinitions="Auto,*,Auto">
        <TitleBar Grid.Row="0" Height="32" Background="{DynamicResource LayerFillColorDefaultBrush}" />

        <Grid Grid.Row="1" ColumnDefinitions="64,*" Margin="12,40,12,12" Name="MainGrid">
            <Border Grid.Column="0" Background="{DynamicResource LayerFillColorDefaultBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel Spacing="0" VerticalAlignment="Top">
                        <Button ToolTip.Tip="{x:Static resources:Strings.Menu_About_Title}" Command="{Binding NavigateToAboutCommand}" Tag="about" Classes="Icon-Button">
                            <ic:PackIconMaterial Kind="Information" Foreground="#888888" BorderThickness="1.5" Width="16" Height="16" />
                        </Button>

                        <Button ToolTip.Tip="{x:Static resources:Strings.About_Translators_Title}" Command="{Binding NavigateToTranslatorsCommand}" Tag="translators" Classes="Icon-Button">
                            <ic:PackIconMaterial Kind="Translate" Foreground="#888888" BorderThickness="1.5" Width="16" Height="16" />
                        </Button>

                        <Button ToolTip.Tip="{x:Static resources:Strings.About_Licenses_Title}" Command="{Binding NavigateToLicensesCommand}" Tag="licenses" Classes="Icon-Button">
                            <ic:PackIconMaterial Kind="License" Foreground="#888888" BorderThickness="1.5" Width="16" Height="16" />
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <TransitioningContentControl
                x:Name="PageContentControl"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{DynamicResource LayerFillColorDefaultBrush}" />
        </Grid>
    </Grid>
</base:AvaloniaWindow>