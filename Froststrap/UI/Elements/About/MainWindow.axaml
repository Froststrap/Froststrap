<base:AvaloniaWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:Froststrap.UI.Elements.About.Pages"
        xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
        xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
        xmlns:resources="clr-namespace:Froststrap.Resources"
        xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.About"
        xmlns:ic="using:IconPacks.Avalonia.Material"
        mc:Ignorable="d"
        x:Class="Froststrap.UI.Elements.About.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{x:Static resources:Strings.About_Title}"
        MinWidth="740" Width="740" Height="440"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Mica"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True">

  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource ApplicationBackgroundColor}">
        <controls:TitleBar Grid.Row="0" Title="{x:Static resources:Strings.About_Title}" Icon="avares://Froststrap/Froststrap.ico" />

        <Grid Grid.Row="1" ColumnDefinitions="64,*" Name="MainGrid">
            <Border Grid.Column="0" Background="{DynamicResource LayerFillColorDefaultBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel Spacing="0" VerticalAlignment="Top" Name="SidebarStackPanel">
                        <controls:IconButton 
                            Classes="nav-button" 
                            ToolTip.Tip="{x:Static resources:Strings.Menu_About_Title}" 
                            Command="{Binding NavigateToAboutCommand}" 
                            Tag="about"
                            Icon="Information"
                            IconSize="20" />

                        <controls:IconButton 
                            Classes="nav-button" 
                            ToolTip.Tip="{x:Static resources:Strings.About_Licenses_Title}" 
                            Command="{Binding NavigateToLicensesCommand}" 
                            Tag="licenses"
                            Icon="License"
                            IconSize="20" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <TransitioningContentControl
                x:Name="PageContentControl"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{DynamicResource LayerFillColorDefaultBrush}" />
        </Grid>
    </Grid>
</base:AvaloniaWindow>