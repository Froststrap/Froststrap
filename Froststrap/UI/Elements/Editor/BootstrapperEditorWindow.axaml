<base:AvaloniaWindow
    x:Class="Froststrap.UI.Elements.Editor.BootstrapperEditorWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
    xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
    xmlns:resources="clr-namespace:Froststrap.Resources"
    xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Editor"
    x:DataType="vm:BootstrapperEditorWindowViewModel"
    SystemDecorations="None"
    Title="{Binding Title}"
    Width="1000" Height="500"
    WindowStartupLocation="CenterScreen">

<Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource ApplicationBackgroundColor}">
        <controls:TitleBar Grid.Row="0" Title="{Binding Title}" 
                           Icon="avares://Froststrap/Froststrap.ico" />

<Ae:TextEditor Name="UIXML" 
               Grid.Row="1"
               Classes="NewTextEditor"
               ShowLineNumbers="True"
               Margin="10"
               Padding="5"
               HorizontalScrollBarVisibility="Auto"
               VerticalScrollBarVisibility="Visible" />

        <Border Grid.Row="2" Background="{DynamicResource PrimaryBackgroundColor}" Padding="10">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <Button Grid.Column="0" 
                        Command="{Binding OpenThemeFolderCommand}"
                        Content="{x:Static resources:Strings.CustomTheme_Editor_OpenThemeDirectory}" />

                <Button Grid.Column="1" Margin="10,0,0,0" 
                        Classes="accent"
                        Command="{Binding PreviewCommand}"
                        Content="{x:Static resources:Strings.CustomTheme_Editor_Preview}" />

                <Button Grid.Column="2" Margin="10,0,0,0" 
                        Classes="accent"
                        Command="{Binding SaveCommand}"
                        Content="{x:Static resources:Strings.CustomTheme_Editor_Save}" />

                <Button Grid.Column="3" Margin="12,0,0,0" 
                        Content="{x:Static resources:Strings.Common_Close}"
                        Click="OnCancelButtonClicked" />
            </Grid>
        </Border>
    </Grid>
</base:AvaloniaWindow>