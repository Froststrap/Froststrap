<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:ui="using:FluentAvalonia.UI.Controls"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:ic="using:IconPacks.Avalonia.Material"
		xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
		xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls">

	<Style Selector="controls|CardExpander.NoUserExpansion">
		<Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
		<Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="CornerRadius" Value="4" />
		<Setter Property="Template">
			<ControlTemplate>
				<Border Name="ContentBorder"
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						CornerRadius="{TemplateBinding CornerRadius}"
						ClipToBounds="True"
						Margin="0,4">
					<StackPanel>
						<Border Padding="16,12">
							<Grid ColumnDefinitions="*, Auto">
								<StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
									<ContentPresenter Content="{TemplateBinding Header}"
													  FontSize="14"
													  FontWeight="Normal"
													  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
													  TextWrapping="Wrap"/>
									<controls:MarkdownTextBlock MarkdownText="{TemplateBinding Description}"
											   FontSize="12"
											   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
											   IsVisible="{TemplateBinding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
											   TextWrapping="Wrap"/>
								</StackPanel>

								<ContentPresenter Grid.Column="1"
												  Content="{TemplateBinding HeaderContent}"
												  VerticalAlignment="Center"
											      HorizontalAlignment="Right"
												  Margin="16,0,0,0"/>
							</Grid>
						</Border>

						<Border Name="PART_ContentContainer" 
								BorderBrush="{TemplateBinding BorderBrush}"
								ClipToBounds="True">
							<Border.Transitions>
								<Transitions>
									<DoubleTransition Property="Height" Duration="0:0:0.25" Easing="CubicEaseOut"/>
									<DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="LinearEasing"/>
								</Transitions>
							</Border.Transitions>

							<ContentPresenter Name="PART_ContentPresenter"
											  Content="{TemplateBinding Content}"
											  Padding="16"/>
						</Border>
					</StackPanel>
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>

	<Style Selector="controls|CardExpander.NoUserExpansion[IsExpanded=True] Border#PART_ContentContainer">
		<Setter Property="Opacity" Value="1" />
		<Setter Property="BorderThickness" Value="0,1,0,0" />
	</Style>

	<Style Selector="controls|CardExpander.NoUserExpansion[IsExpanded=False] Border#PART_ContentContainer">
		<Setter Property="Opacity" Value="0" />
		<Setter Property="Height" Value="0" />
		<Setter Property="BorderThickness" Value="0" />
	</Style>

	<Style Selector="controls|CardExpander.NoUserExpansion:pointerover">
		<Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
	</Style>

	<Style Selector="AvaloniaEdit|TextEditor">
        <Setter Property="Foreground" Value="{DynamicResource NewTextEditorForeground}" />
        <Setter Property="Background" Value="{DynamicResource NewTextEditorBackground}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                    <ScrollViewer Name="PART_ScrollViewer"
                                  Padding="{TemplateBinding Padding}"
                                  HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                  VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                  AllowAutoHide="True">
                    </ScrollViewer>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="AvaloniaEdit|TextEditor[WordWrap=True] /template/ ScrollViewer#PART_ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

	<Style Selector="DataGrid">
    <Setter Property="Background" Value="{DynamicResource NormalDarkAndLightBackground}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="HorizontalGridLinesBrush" Value="#11000000" />
    <Setter Property="VerticalGridLinesBrush" Value="Transparent" />

    <Style Selector="^ DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="8,0,12,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>
    </Style>

    <Style Selector="^ DataGridCell">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="6,0,6,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="#14000000" />
        </Style>
    </Style>
</Style>

	<!-- Icon Button Style -->
	<Design.PreviewWith>
		<StackPanel Spacing="10" Margin="20" Background="#2D2D2D">
			<Button Classes="icon-button">
				<Panel IsHitTestVisible="False">
					<ic:PackIconMaterial Kind="Information" BorderThickness="1.5" Width="16" Height="16" />
				</Panel>
			</Button>
		</StackPanel>
	</Design.PreviewWith>

	<Style Selector="Button.icon-button">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Foreground" Value="#888888" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="MinWidth" Value="64" />
		<Setter Property="Height" Value="64" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Cursor" Value="Hand" />
		<Setter Property="CornerRadius" Value="4" />
		<Setter Property="Template">
			<ControlTemplate TargetType="Button">
				<Border
					Name="PART_BorderBackground"
					Background="{TemplateBinding Background}"
					CornerRadius="8"
					Padding="{TemplateBinding Padding}"
					Margin="8">
					<ContentPresenter
						Name="PART_ContentPresenter"
						Content="{TemplateBinding Content}"
						ContentTemplate="{TemplateBinding ContentTemplate}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center" />
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>

	<Style Selector="Button.icon-button:pointerover">
		<Setter Property="Background" Value="#333333" />
		<Setter Property="Foreground" Value="#888888" />
	</Style>
</Styles>