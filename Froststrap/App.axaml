<Application
    x:Class="Froststrap.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sty="using:FluentAvalonia.Styling"
    xmlns:converters="using:Froststrap.UI.Converters"
    RequestedThemeVariant="Dark">

	<Application.Styles>
		<sty:FluentAvaloniaTheme PreferSystemTheme="True" />

		<Style Selector="Button.icon-button">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="#888888" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="MinWidth" Value="64" />
			<Setter Property="Height" Value="64" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Template">
				<ControlTemplate TargetType="Button">
					<Border 
						Name="PART_BorderBackground"
						Background="{TemplateBinding Background}"
						CornerRadius="8"
						Padding="{TemplateBinding Padding}"
						Margin="8">
						<ContentPresenter 
							Name="PART_ContentPresenter"
							Content="{TemplateBinding Content}"
							ContentTemplate="{TemplateBinding ContentTemplate}"
							HorizontalAlignment="Center"
							VerticalAlignment="Center" />
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>

		<Style Selector="Button.icon-button:pointerover">
			<Setter Property="Background" Value="#333333" />
			<Setter Property="Foreground" Value="#ffffff" />
		</Style>

		<Style Selector="Button.icon-button:pressed">
			<Setter Property="Background" Value="#00d4ff" />
			<Setter Property="Foreground" Value="#000000" />
		</Style>
	</Application.Styles>

	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://Froststrap/UI/Style/Dark.axaml" />
				<ResourceInclude Source="avares://Froststrap/UI/Style/Default.axaml" />
			</ResourceDictionary.MergedDictionaries>

			<!-- Fonts -->
			<FontFamily x:Key="Rubik">
				avares://Froststrap/Resources/Fonts/Rubik-VariableFont_wght.ttf
			</FontFamily>

			<!-- Accent brushes -->
			<SolidColorBrush
				x:Key="AccentColorSecondaryBrush"
				Color="{DynamicResource SystemAccentColorSecondary}" />

			<SolidColorBrush
				x:Key="AccentColorTertiaryBrush"
				Color="{DynamicResource SystemAccentColorTertiary}" />

			<!-- Converters -->
			<converters:StringFormatConverter x:Key="StringFormatConverter" />
			<converters:RangeConverter x:Key="RangeConverter" />
			<converters:EnumNameConverter x:Key="EnumNameConverter" />
			<converters:SettingsControlTemplateSelector x:Key="SettingsControlSelector" />
			<converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
			<converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
			<converters:NumberAbbreviationConverter x:Key="NumberAbbreviationConverter" />
		</ResourceDictionary>
	</Application.Resources>
</Application>