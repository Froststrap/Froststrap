<base:WpfUiWindow
    x:Class="Bloxstrap.UI.Elements.Settings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Bloxstrap.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dmodels="clr-namespace:Bloxstrap.UI.ViewModels.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Bloxstrap.UI.Elements.Settings.Pages"
    xmlns:resources="clr-namespace:Bloxstrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Strings.Menu_Title}"
    Width="1125"
    Height="700"
    MinWidth="250"
    MinHeight="250"
    d:DataContext="{d:DesignInstance dmodels:MainWindowViewModel,
                                     IsDesignTimeCreatable=True}"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}"
    Closed="WpfUiWindow_Closed"
    Closing="WpfUiWindow_Closing"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource ApplicationBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:Snackbar
            x:Name="AlreadyRunningSnackbar"
            Title="{x:Static resources:Strings.Menu_AlreadyRunning_Title}"
            Grid.RowSpan="10"
            Margin="200,0,200,40"
            Panel.ZIndex="10"
            Background="{DynamicResource NormalDarkAndLightBackground}"
            Icon="Info20"
            Message="{x:Static resources:Strings.Menu_AlreadyRunning_Caption}"
            Timeout="5000" />

        <ui:Snackbar
            x:Name="SettingsSavedSnackbar"
            Title="{x:Static resources:Strings.Menu_SettingsSaved_Title}"
            Grid.RowSpan="10"
            Margin="200,0,200,40"
            Panel.ZIndex="9"
            Background="#CC1A1A1A"
            Icon="CheckmarkCircle24"
            Message="{x:Static resources:Strings.Menu_SettingsSaved_Message}"
            Timeout="3000" />

        <ui:TitleBar
            x:Name="RootTitleBar"
            Title="{x:Static resources:Strings.Menu_Title}"
            Grid.Row="0"
            Padding="8"
            ForceShutdown="False"
            Icon="pack://application:,,,/Bloxstrap.ico"
            MinimizeToTray="False"
            UseSnapLayout="True" />

        <Grid
            x:Name="RootGrid"
            Grid.Row="1"
            Margin="10,8,0,0"
            Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationCompact
                x:Name="RootNavigation"
                Grid.Row="1"
                Grid.Column="0"
                MaxWidth="215"
                Margin="0,0,20,0"
                FooterAlwaysVisible="True"
                Frame="{Binding ElementName=RootFrame}"
                IsExpanded="{Binding IsSidebarExpanded, Mode=TwoWay}"
                SelectedPageIndex="0">
                <ui:NavigationCompact.Items>
                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Menu_Integrations_Title}"
                        Icon="Add28"
                        IconSize="20"
                        PageType="{x:Type pages:IntegrationsPage}"
                        Tag="integrations" />
                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Menu_Behaviour_Title}"
                        Icon="PlaySettings20"
                        IconSize="20"
                        PageType="{x:Type pages:BehaviourPage}"
                        Tag="bootstrapper" />
                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Menu_Mods_Title}"
                        Icon="WrenchScrewdriver20"
                        IconSize="20"
                        PageType="{x:Type pages:ModsPage}"
                        Tag="mods" />
                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Menu_FastFlags_Title}"
                        Icon="Flag24"
                        IconSize="20"
                        PageType="{x:Type pages:FastFlagsPage}"
                        Tag="fastflags" />
                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Menu_Appearance_Title}"
                        Icon="PaintBrush24"
                        IconSize="20"
                        PageType="{x:Type pages:AppearancePage}"
                        Tag="appearance" />
                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Menu_RegionSelector_Title}"
                        Icon="Earth24"
                        IconSize="20"
                        PageType="{x:Type pages:RegionSelectorPage}"
                        Tag="regionselector" />
                    <ui:NavigationItem
                        x:Name="gbs"
                        Content="{x:Static resources:Strings.Menu_RobloxSettings_Title}"
                        Icon="SquareHintApps24"
                        IconSize="20"
                        PageType="{x:Type pages:RobloxSettingsPage}"
                        Tag="robloxsettings" />
                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Common_Shortcuts}"
                        Icon="Apps28"
                        IconSize="20"
                        PageType="{x:Type pages:ShortcutsPage}"
                        Tag="shortcuts" />

                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Menu_FastFlagEditor_Title}"
                        Icon="EditSettings20"
                        IconSize="20"
                        PageType="{x:Type pages:FastFlagEditorPage}"
                        Tag="fastflageditor"
                        Visibility="Collapsed" />
                    <ui:NavigationItem
                        Content="Community Mods"
                        Icon="BuildingShop24"
                        IconSize="20"
                        PageType="{x:Type pages:CommunityModsPage}"
                        Tag="communitymods"
                        Visibility="Collapsed" />
                    <ui:NavigationItem
                        Content="Preset Mods"
                        Icon="BuildingShop24"
                        IconSize="20"
                        PageType="{x:Type pages:ModsPresetsPage}"
                        Tag="presetmods"
                        Visibility="Collapsed" />
                    <ui:NavigationItem
                        Content="Mod Generator"
                        Icon="BuildingShop24"
                        IconSize="20"
                        PageType="{x:Type pages:ModGeneratorPage}"
                        Tag="modgenerator"
                        Visibility="Collapsed" />
                </ui:NavigationCompact.Items>
                <ui:NavigationCompact.Footer>
                    <ui:NavigationItem
                        Command="{Binding OpenAccountManagerCommand, Mode=OneTime}"
                        Content="{x:Static resources:Strings.Menu_AccountManager_Title}"
                        Icon="People24"
                        IconSize="20"
                        Tag="accountmanager" />
                    <ui:NavigationItem
                        Content="{x:Static resources:Strings.Common_Settings}"
                        Icon="Settings20"
                        IconSize="20"
                        PageType="{x:Type pages:ChannelPage}"
                        Tag="channel" />
                    <ui:NavigationItem
                        Margin="0,0,0,12"
                        Command="{Binding OpenAboutCommand, Mode=OneTime}"
                        Content="{x:Static resources:Strings.Menu_About_Title}"
                        Icon="WeatherSnowflake48"
                        IconSize="21" />
                </ui:NavigationCompact.Footer>
            </ui:NavigationCompact>

            <Grid
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <ui:InfoBar
                    x:Name="AlertBar"
                    Grid.Row="0"
                    Margin="0,0,12,0"
                    Padding="8"
                    IsClosable="False"
                    IsOpen="True"
                    Message=""
                    Severity="Warning"
                    Visibility="Collapsed" />
                <ui:Breadcrumb
                    Grid.Row="1"
                    Margin="0,0,0,5"
                    Navigation="{Binding ElementName=RootNavigation}" />
                <Frame x:Name="RootFrame" Grid.Row="2" />
            </Grid>
        </Grid>

        <StatusBar
            x:Name="RootStatusBar"
            Grid.Row="2"
            Padding="12,6"
            BorderThickness="0,1,0,0">

            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!--  Test Mode  -->
            <StatusBarItem Grid.Column="0" VerticalAlignment="Center">
                <StackPanel
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:ToggleSwitch
                        Height="22"
                        VerticalAlignment="Center"
                        IsChecked="{Binding TestModeEnabled, Mode=TwoWay}" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13.5"
                        FontWeight="Medium"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="{x:Static resources:Strings.Menu_TestMode}" />
                </StackPanel>
            </StatusBarItem>

            <!--  Save & Launch  -->
            <StatusBarItem
                Grid.Column="2"
                Margin="0,0,4,0"
                VerticalAlignment="Center">
                <ui:Button
                    x:Name="LaunchButton"
                    Height="32"
                    Padding="14,0"
                    Appearance="Primary"
                    Click="LaunchButton_Click"
                    Content="{x:Static resources:Strings.Menu_SaveAndLaunch}"
                    FontWeight="Medium">
                    <ui:Button.ContextMenu>
                        <ContextMenu x:Name="LaunchMenu">
                            <MenuItem Command="{Binding SaveAndLaunchPlayerCommand}" Header="Launch Roblox Player">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Games24" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Command="{Binding SaveAndLaunchStudioCommand}" Header="Launch Roblox Studio">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="TextBulletListSquareToolbox20" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ui:Button.ContextMenu>
                </ui:Button>
            </StatusBarItem>

            <!--  Restart  -->
            <StatusBarItem
                Grid.Column="3"
                Margin="0,0,4,0"
                VerticalAlignment="Center">
                <ui:Button
                    Height="32"
                    Padding="14,0"
                    Appearance="Primary"
                    Command="{Binding RestartAppCommand}"
                    Content="{x:Static resources:Strings.Menu_Restart}"
                    FontWeight="Medium" />
            </StatusBarItem>

            <!--  Save  -->
            <StatusBarItem
                Grid.Column="4"
                Margin="0,0,4,0"
                VerticalAlignment="Center">
                <ui:Button
                    Height="32"
                    Padding="14,0"
                    Appearance="Primary"
                    Command="{Binding SaveSettingsCommand}"
                    Content="{x:Static resources:Strings.Menu_Save}"
                    FontWeight="Medium" />
            </StatusBarItem>

            <!--  Close  -->
            <StatusBarItem
                Grid.Column="5"
                Margin="0,0,0,0"
                VerticalAlignment="Center">
                <ui:Button
                    Height="32"
                    Padding="14,0"
                    Command="{Binding CloseWindowCommand}"
                    Content="{x:Static resources:Strings.Common_Close}"
                    FontWeight="Medium" />
            </StatusBarItem>
        </StatusBar>

        <Grid
            x:Name="LoadingOverlay"
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="9999"
            Background="#A0000000"
            Visibility="Collapsed">

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border
                    Padding="32"
                    Background="{DynamicResource NormalDarkAndLightBackground}"
                    CornerRadius="16"
                    Effect="{DynamicResource ControlShadow}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">

                        <!--  Loading Text  -->
                        <TextBlock
                            x:Name="LoadingOverlayText"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Loading..." />

                        <ui:ProgressRing
                            Width="60"
                            Height="60"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsIndeterminate="True" />

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</base:WpfUiWindow>