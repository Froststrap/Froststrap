<base:WpfUiWindow
    x:Class="Bloxstrap.UI.Elements.AccountManagers.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Bloxstrap.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Bloxstrap.UI.Elements.AccountManagers.Pages"
    xmlns:resources="clr-namespace:Bloxstrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Account Manager"
    Width="1000"
    Height="675"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource ApplicationBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="RootTitleBar"
            Title="Account Manager"
            Grid.Row="0"
            Padding="8"
            ForceShutdown="True"
            Icon="pack://application:,,,/Bloxstrap.ico"
            MinimizeToTray="False"
            UseSnapLayout="True" />

        <Grid
            x:Name="RootGrid"
            Grid.Row="1"
            Margin="12,12,0,0"
            Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationStore
                x:Name="RootNavigation"
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,12,0"
                Frame="{Binding ElementName=RootFrame}"
                SelectedPageIndex="0">
                <ui:NavigationStore.Items>
                    <ui:NavigationItem
                        Margin="0,0,0,12"
                        Content="Accounts"
                        FontWeight="Medium"
                        Icon="PersonAccounts24"
                        PageType="{x:Type pages:AccountsPage}"
                        Tag="accounts" />
                    <ui:NavigationItem
                        x:Name="friends"
                        Margin="0,0,0,12"
                        Content="Friends"
                        FontWeight="Medium"
                        Icon="People24"
                        PageType="{x:Type pages:FriendsPage}"
                        Tag="friends" />
                    <ui:NavigationItem
                        x:Name="games"
                        Margin="0,0,0,12"
                        Content="Games"
                        FontWeight="Medium"
                        Icon="Games24"
                        PageType="{x:Type pages:GamesPage}"
                        Tag="games" />
                </ui:NavigationStore.Items>
            </ui:NavigationStore>

            <Frame
                x:Name="RootFrame"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1" />
        </Grid>

        <Grid
            x:Name="LoadingOverlay"
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="9999"
            Background="#A0000000"
            Visibility="Collapsed">

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border
                    Padding="32"
                    Background="{DynamicResource NormalDarkAndLightBackground}"
                    CornerRadius="16"
                    Effect="{DynamicResource ControlShadow}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">

                        <TextBlock
                            x:Name="LoadingOverlayText"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Loading..." />
                        <ui:ProgressRing
                            Width="60"
                            Height="60"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsIndeterminate="True" />

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</base:WpfUiWindow>
